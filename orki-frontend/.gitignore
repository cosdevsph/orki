# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ==============================
# Dependencies
# ==============================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==============================
# Testing
# ==============================
/coverage

# ==============================
# Next.js
# ==============================
/.next/
/out/

# ==============================
# Production
# ==============================
/build

# ==============================
# Environment Variables (CRITICAL)
# ==============================
# All .env files contain secrets — NEVER commit them.
# Only .env.example (with placeholder values) is safe to commit.
.env
.env.*
.env.local
.env.production
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ==============================
# Firebase / Secrets (CRITICAL)
# ==============================
# Firebase Admin SDK service account files must NEVER appear in the frontend.
# These are backend-only credentials.
serviceAccountKey.json
*serviceAccount*.json
*firebase-adminsdk*.json
*-firebase-adminsdk-*.json

# ==============================
# Debug Logs
# ==============================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==============================
# Misc / IDE / OS
# ==============================
.DS_Store
*.pem
.vscode/
.idea/

# ==============================
# Vercel
# ==============================
.vercel

# ==============================
# TypeScript
# ==============================
*.tsbuildinfo
next-env.d.ts
